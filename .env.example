# ---- Backend -----------------------------------------------------------
# Required (fallback pool): get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Recommended for fast debates — direct free-tier keys on fast hardware.
# Any subset works; agents fall back to OpenRouter when a key is missing.
# GROQ_API_KEY=gsk_...        # https://console.groq.com/keys        (Reviewer + Consensus)
# CEREBRAS_API_KEY=csk-...    # https://cloud.cerebras.ai            (Engineer)
# GEMINI_API_KEY=AIza...      # https://aistudio.google.com/apikey   (Analyst)
# Override the direct models if needed:
# DIRECT_MODEL_ANALYST=gemini-2.5-flash
# DIRECT_MODEL_ENGINEER=zai-glm-4.7
# DIRECT_MODEL_REVIEWER=llama-3.3-70b-versatile
# DIRECT_MODEL_CONSENSUS=llama-3.3-70b-versatile

# PostgreSQL (local Docker Compose defaults shown; use your Neon URL in prod).
# Compose maps the container to host port 5433 to avoid clashing with a native install.
DATABASE_URL=jdbc:postgresql://localhost:5433/convergeai
DATABASE_USERNAME=converge
DATABASE_PASSWORD=converge

# Comma-separated origins allowed for CORS + WebSocket handshake
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional: override the free-tier models if OpenRouter rotates availability.
# Check the current catalog: curl -s https://openrouter.ai/api/v1/models | grep ':free'
# MODEL_ANALYST=openai/gpt-oss-120b:free
# MODEL_ENGINEER=qwen/qwen3-next-80b-a3b-instruct:free
# MODEL_REVIEWER=meta-llama/llama-3.3-70b-instruct:free
# MODEL_CONSENSUS=meta-llama/llama-3.3-70b-instruct:free

# ---- Frontend (frontend/.env) -------------------------------------------
# VITE_API_BASE_URL=http://localhost:8080
